# ── CHOOSE YOUR LLM (fill ONE section) ──────────────────────────────────────
# Default: Ollama Cloud — signed in mode (no API key needed)
# Just start the app and sign in via the Settings panel in the UI.

# Option A: Ollama Cloud — Signed In (recommended — no key needed)
LLM_PROVIDER=ollama_cloud
LLM_MODEL=auto
LLM_API_KEY=

# Option B: Ollama Cloud — API Key mode
# LLM_PROVIDER=ollama_cloud
# OLLAMA_CLOUD_API_KEY=your_api_key_here

# Option C: Ollama Local (must have Ollama installed + model pulled locally)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=qwen2.5:7b

# Option D: Other cloud providers (OpenAI, Anthropic, Gemini, Groq)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
#
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
#
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
#
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...

# ── Vector Database ──────────────────────────────────────────────────────────
# Default: local Qdrant in Docker (no account needed — just docker compose up)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Optional: use Qdrant Cloud instead
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# ── HuggingFace (embedding + reranker models) ────────────────────────────────
# Models are auto-downloaded on first run (~3.7 GB total, one-time)
HF_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
HF_RERANKER_MODEL=BAAI/bge-reranker-large
# Optional: speeds up model downloads (get token at huggingface.co/settings/tokens)
HF_TOKEN=
# Optional: force CPU/CUDA/MPS (auto-detected if empty)
EMBED_DEVICE=

# ── Advanced ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
APP_PORT=8000
APP_HOST=0.0.0.0
OLLAMA_CLOUD_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
LLM_BASE_URL=
