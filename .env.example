# ── CHOOSE YOUR LLM (fill ONE section) ──────────────────────────────────────
# Default: Local Ollama — runs fully inside Docker, ZERO host setup needed!
# Just run ./start.sh (or start.bat) and everything is configured automatically.

# Option A: Local Ollama via Docker (DEFAULT — recommended, no API key needed)
# Ollama runs as a Docker service — no host installation required.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
LLM_API_KEY=

# Option B: Ollama Cloud — Signed In (if you prefer Ollama Cloud)
# LLM_PROVIDER=ollama_cloud
# LLM_MODEL=gpt-oss:120b-cloud
# OLLAMA_CLOUD_API_KEY=
#
# Test your account's cloud access:
#   python scripts/test_ollama_cloud_models.py --base-url http://localhost:11434 --pull
#
# Option B2: Ollama Cloud — Direct API key mode
# LLM_PROVIDER=ollama_cloud
# LLM_MODEL=gpt-oss:120b
# OLLAMA_CLOUD_API_KEY=your_api_key_here

# Option C: Use a different local model (change the model name below)
# LLM_PROVIDER=ollama
# OLLAMA_CHAT_MODEL=llama3.2:3b          # smaller / faster
# OLLAMA_CHAT_MODEL=mistral:7b           # alternative
# OLLAMA_CHAT_MODEL=qwen2.5:14b          # higher quality

# Option D: Other cloud providers (OpenAI, Anthropic, Gemini, Groq, NVIDIA)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
#
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
#
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
#
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
#
# LLM_PROVIDER=nvidia
# LLM_MODEL=mistralai/mistral-large-3-675b-instruct-2512
# NVIDIA_API_KEY=nvapi-...

# ── Vector Database ──────────────────────────────────────────────────────────
# Default: local Qdrant in Docker (no account needed — just docker compose up)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Optional: use Qdrant Cloud instead
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# ── HuggingFace (embedding + reranker models) ────────────────────────────────
# Models are auto-downloaded on first run (~3.7 GB total, one-time)
HF_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
HF_RERANKER_MODEL=BAAI/bge-reranker-large
# Optional: speeds up model downloads (get token at huggingface.co/settings/tokens)
HF_TOKEN=
# Optional: force CPU/CUDA/MPS (auto-detected if empty)
EMBED_DEVICE=

# ── Advanced ─────────────────────────────────────────────────────────────────
# When using Docker Compose (default), Ollama runs as a service named 'ollama'
# Use http://ollama:11434 inside Docker, or http://localhost:11434 from host
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
APP_PORT=8000
APP_HOST=0.0.0.0
OLLAMA_CLOUD_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
LLM_BASE_URL=
