# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
# Get these from https://cloud.qdrant.io → your cluster → API Keys
QDRANT_URL=
QDRANT_API_KEY=

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding
OLLAMA_CHAT_MODEL=qwen2.5:7b

# ── LLM Provider (optional — users can override in the app Settings UI) ───────
# Provider: ollama | openai | anthropic | gemini | groq | openrouter
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=
LLM_BASE_URL=

# ── FastAPI ───────────────────────────────────────────────────────────────────
APP_PORT=8000
APP_HOST=127.0.0.1
